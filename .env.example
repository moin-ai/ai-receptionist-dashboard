# GoHighLevel (sub-account Private Integration Token)
GHL_API_TOKEN=
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_LOCATION_ID=

# App display name (your GHL sub-account name)
NEXT_PUBLIC_APP_NAME=AI Receptionist

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (appointment-booked email)
RESEND_API_KEY=
NOTIFY_EMAIL_FROM=AI Receptionist <onboarding@resend.dev>
NOTIFY_EMAIL_TO=

# Shared secret for the GHL workflow webhook
WEBHOOK_SECRET=

# Postgres pooler (migrations only; optional)
DATABASE_URL=
